# ARQITEKT Configuration
# Copy this file to .env and fill in your values

# ─── Auth (optional — set to true for cloud deployment) ───
AUTH_ENABLED=false
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── GitHub OAuth (required when AUTH_ENABLED=true) ───
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3334/api/auth/github/callback

# ─── GitHub PAT (for GitHub API access — separate from OAuth login) ───
GITHUB_TOKEN=

# ─── LLM ───
LLM_PROVIDER=github
LLM_MODEL=gpt-4o
LLM_ENDPOINT=https://models.inference.ai.azure.com

# ─── Server ───
PORT=3334
CORS_ORIGINS=http://localhost:5173,http://localhost:3333
BODY_LIMIT=1mb
LLM_TIMEOUT=60000
MAX_RUNNING_APPS=5

# ─── Public URL (frontend URL for OAuth redirect) ───
PUBLIC_URL=http://localhost:5173

# ─── Docker overrides (only needed in containers) ───
# WORKSPACE_ROOT=/workspace
# HUB_ROOT=/app

# ─── Node environment ───
NODE_ENV=development
