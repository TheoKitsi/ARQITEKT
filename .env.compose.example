# ARQITEKT Docker Compose Environment Variables
# Copy this file to .env and fill in your values.

# ── Hub ──────────────────────────────────────────────────────────────
# Port to expose the Hub dashboard (default: 80)
HUB_PORT=80

# ── Server ───────────────────────────────────────────────────────────
PORT=3334
NODE_ENV=production

# Body size limit for POST requests
BODY_LIMIT=1mb

# LLM request timeout in milliseconds
LLM_TIMEOUT=60000

# Maximum concurrent running apps
MAX_RUNNING_APPS=5

# ── LLM Configuration ───────────────────────────────────────────────
# Primary LLM API key (referenced in config/llm.yaml as api_key_env)
ARQITEKT_LLM_KEY=

# GitHub token (used for GitHub Models fallback + GitHub OAuth)
GITHUB_TOKEN=

# ── Authentication (optional, disabled by default) ───────────────────
AUTH_ENABLED=false

# JWT secret — CHANGE THIS in production
JWT_SECRET=change-me-in-production

# JWT token expiration
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── GitHub OAuth (only needed when AUTH_ENABLED=true) ────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3334/api/auth/github/callback

# ── OIDC / SSO (optional alternative to GitHub OAuth) ────────────────
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:3334/api/auth/oidc/callback
OIDC_SCOPES=openid profile email

# ── SMTP Email Notifications (optional) ─────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ARQITEKT <noreply@arqitekt.dev>

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:5173

# ── HTTPS / TLS (docker-compose.prod.yml only) ──────────────────────
# Domain name for Let's Encrypt certificate
DOMAIN=arqitekt.example.com

# Email for Let's Encrypt notifications
CERTBOT_EMAIL=admin@example.com
